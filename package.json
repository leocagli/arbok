{
  "name": "arbok",
  "version": "0.1.0",
  "description": "Temporary user profiles linked to blockchain wallets, with cross-chain replication and per-app extensions - powered by Arbok.",
  "license": "ISC",
  "author": "",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "release": "pnpm typecheck && pnpm test && changelogen --release && bumpp --commit --tag --push"
  },
  "dependencies": {
    "@arkiv-network/sdk": "latest"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^25.3.3",
    "bumpp": "^10.4.1",
    "changelogen": "^0.5.7",
    "tsdown": "^1.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
